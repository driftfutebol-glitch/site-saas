# =====================================================================
#  MODELO de variáveis de ambiente.
#  Copie este arquivo para ".env.local" e preencha. NUNCA comite o .env.local.
# =====================================================================

# Segredo para assinar as sessões (login). Gere um aleatório de 32+ caracteres.
# Gerar:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=

# URL pública do app. Em produção, a URL do seu site (ex: https://ferrazcode.com.br)
APP_URL=http://localhost:3000

# Banco de dados.
# Local: pode manter file:./data/app.db.
# Vercel/producao: use a URL libsql://... do Turso e o token correspondente.
DATABASE_URL=file:./data/app.db
DATABASE_AUTH_TOKEN=

# Login com Google (opcional) — https://console.cloud.google.com/apis/credentials
# Cadastre o Redirect URI:  <APP_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# E-mails (separados por vírgula) com acesso ao painel /admin.
ADMIN_EMAILS=
